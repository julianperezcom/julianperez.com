---
import BaseLayout from '../layouts/BaseLayout.astro'
import '../styles/global.css'
---
<BaseLayout title="404 — Page not found | Julian Perez" description="">
  <div style="min-height:100vh;background:#0E0E0E;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px 24px;font-family:inherit;">
    <div style="font-size:0.62rem;letter-spacing:0.35em;text-transform:uppercase;color:#555;margin-bottom:24px;">404</div>
    <h1 style="font-size:clamp(2rem,6vw,4rem);font-weight:800;letter-spacing:-0.04em;color:#fff;margin-bottom:16px;line-height:1.1;">Page not found</h1>
    <p style="font-size:0.9rem;color:#666;line-height:1.7;max-width:360px;margin-bottom:48px;">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" style="padding:14px 40px;background:#fff;color:#0E0E0E;font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;font-weight:700;text-decoration:none;transition:opacity 0.2s;">← Back to julianperez.com</a>
  </div>
</BaseLayout>
