---
import { fetchBandcampItems } from '../../lib/bandcamp'

let jpItems: any[] = []
let giradaItems: any[] = []
let fasItems: any[] = []

try {
  [jpItems, giradaItems, fasItems] = await Promise.all([
    fetchBandcampItems('jp'),
    fetchBandcampItems('girada'),
    fetchBandcampItems('fas'),
  ])
} catch (e) {
  jpItems = []
  giradaItems = []
  fasItems = []
}
---

<!-- STORE -->
<div class="store-section" id="store">
  <div class="section-wrap" style="padding-bottom:32px;">
    <div class="section-eyebrow" data-i18n="store.eyebrow">Store</div>
      <div class="section-title" data-i18n="store.title" style="color:#C8C7C3;">Shop</div>
    <p class="section-sub" data-i18n="store.sub">Vinyls, LPs and tracks on Bandcamp. Worldwide shipping.</p>
    <div class="music-tabs" style="margin-bottom:0;">
      <button class="tab-btn active" onclick="switchStore('jp',this)">Julian Perez</button>
      <button class="tab-btn" onclick="switchStore('girada',this)">Girada Unlimited</button>
      <button class="tab-btn" onclick="switchStore('fas',this)">Fathers &amp; Sons</button>
    </div>
  </div>

  <!-- JP panel -->
  <div id="store-jp" class="store-grid">
    {jpItems.length === 0 ? (
      <div class="store-loading" data-i18n="store.coming_soon">Coming soon</div>
    ) : (
      jpItems.map((item: any) => (
        <a href={item.url} target="_blank" rel="noopener noreferrer" class="store-item">
          <div class="store-cover">
            <img src={item.imageUrl} alt={item.title} />
          </div>
          <div class="store-info">
            <div class="store-title">{item.title}</div>
            {item.artist && <div class="store-label-name">{item.artist}</div>}
            <div class="store-buy" data-i18n="store.view_bandcamp">View on Bandcamp ↗</div>
          </div>
        </a>
      ))
    )}
  </div>

  <!-- Girada panel -->
  <div id="store-girada" class="store-grid" style="display:none;">
    {giradaItems.length === 0 ? (
      <div class="store-loading" data-i18n="store.coming_soon">Coming soon</div>
    ) : (
      giradaItems.map((item: any) => (
        <a href={item.url} target="_blank" rel="noopener noreferrer" class="store-item">
          <div class="store-cover">
            <img src={item.imageUrl} alt={item.title} />
          </div>
          <div class="store-info">
            <div class="store-title">{item.title}</div>
            {item.artist && <div class="store-label-name">{item.artist}</div>}
            <div class="store-buy" data-i18n="store.view_bandcamp">View on Bandcamp ↗</div>
          </div>
        </a>
      ))
    )}
  </div>

  <!-- FAS panel -->
  <div id="store-fas" class="store-grid" style="display:none;">
    {fasItems.length === 0 ? (
      <div class="store-loading" data-i18n="store.coming_soon">Coming soon</div>
    ) : (
      fasItems.map((item: any) => (
        <a href={item.url} target="_blank" rel="noopener noreferrer" class="store-item">
          <div class="store-cover">
            <img src={item.imageUrl} alt={item.title} />
          </div>
          <div class="store-info">
            <div class="store-title">{item.title}</div>
            {item.artist && <div class="store-label-name">{item.artist}</div>}
            <div class="store-buy" data-i18n="store.view_bandcamp">View on Bandcamp ↗</div>
          </div>
        </a>
      ))
    )}
  </div>

  <div class="section-wrap" style="padding-top:32px;padding-bottom:48px;">
    <div id="store-bc-link">
      <a href="https://julianperez.bandcamp.com" target="_blank" style="font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;font-weight:700;color:var(--black);text-decoration:none;border-bottom:1.5px solid var(--black);padding-bottom:3px;">Ver todos en julianperez.bandcamp.com →</a>
    </div>
  </div>
</div>

<style>
  .store-item {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
</style>

<script>
  const STORE_ACCOUNTS: Record<string, { url: string; label: string }> = {
    jp:     { url: 'https://julianperez.bandcamp.com',              label: 'julianperez.bandcamp.com' },
    girada: { url: 'https://giradaunlimited.bandcamp.com',          label: 'giradaunlimited.bandcamp.com' },
    fas:    { url: 'https://fathersandsonsproductions.bandcamp.com', label: 'fathersandsonsproductions.bandcamp.com' },
  }

  let currentStoreTab = 'jp';

  function updateBcLink(tab: string) {
    const a = STORE_ACCOUNTS[tab]
    const t = (window as any).__t__ || {}
    const viewAll = t['store.view_all'] || 'View all on'
    const el = document.getElementById('store-bc-link')
    if (el) {
      el.innerHTML = `<a href="${a.url}" target="_blank" style="font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;font-weight:700;color:var(--black);text-decoration:none;border-bottom:1.5px solid var(--black);padding-bottom:3px;">${viewAll} ${a.label} →</a>`
    }
  }

  function switchStore(tab: string, btn: HTMLElement) {
    currentStoreTab = tab;
    document.querySelectorAll('#store .tab-btn').forEach(b => b.classList.remove('active'))
    btn.classList.add('active');
    ['jp', 'girada', 'fas'].forEach(t => {
      const panel = document.getElementById('store-' + t) as HTMLElement | null
      if (panel) panel.style.display = t === tab ? 'grid' : 'none'
    })
    updateBcLink(tab)
  }

  document.addEventListener('langchange', () => {
    updateBcLink(currentStoreTab);
  });

  (window as any).switchStore = switchStore
</script>
