      { title: 'Premiere: Hear Girada Unlimited\'s Cure Music Debut — A Ricardo Villalobos Favourite', source: 'XLR8R', url: 'https://xlr8r.com/news/premiere-hear-girada-unlimiteds-cure-music-debut/' },
