// Use Sanity data if available, otherwise fall back to static
const displayAssets = assets.length > 0 ? assets : staticAssets
const hasRefs = refs.length > 0
---

<div class="press-section" id="press">
  <div class="section-wrap">
    <div class="section-eyebrow" data-i18n="press.eyebrow">Press</div>
    <div class="press-grid">
      <div>
        <div class="section-title" style="margin-bottom:24px;">Bio</div>
        <p class="press-bio" data-lang="en" set:html={bio?.content ?? staticBio} />
        <p class="press-bio" data-lang="es" style="display:none;" set:html={staticBioES} />
      </div>
      <div>
        <div class="section-title" style="margin-bottom:24px;">Press Kit</div>
        <div class="press-assets">
          {displayAssets.map((asset: any) => (
            <div class="press-asset">
              <div>
                <div class="press-asset-name">{asset.name ?? asset.title}</div>
                <div class="press-asset-meta">{asset.meta ?? asset.fileInfo ?? ''}</div>
              </div>
              <a href={asset.url ?? asset.file?.asset?.url ?? '#'} class="press-download" target="_blank" rel="noopener" data-i18n="press.download">Download</a>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- PRESS REFERENCES -->
    <div class="press-refs-title">Media &amp; Press References</div>

    {hasRefs
      ? categories.map((cat) => (
          refsByCategory[cat].length > 0 && (
            <div class="press-refs-group">
              <div class="press-refs-group-name">{cat}</div>
              {refsByCategory[cat].map((ref: any) => (
                <div class="press-ref">
                  <div class="press-ref-left">
                    <div class="press-ref-title">{ref.title}</div>
                    <div class="press-ref-source">{ref.source}{ref.date ? ` · ${ref.date}` : ''}</div>
                  </div>
                  <a href={ref.url} target="_blank" rel="noopener" class="press-ref-link" data-i18n="press.view">View</a>
                </div>
              ))}
            </div>
          )
        ))
      : staticRefGroups.map((group) => (
          <div class="press-refs-group">
            <div class="press-refs-group-name">{group.name}</div>
            {group.refs.map((ref) => (
              <div class="press-ref">
                <div class="press-ref-left">
                  <div class="press-ref-title">{ref.title}</div>
                  <div class="press-ref-source">{ref.source}</div>
                </div>
                <a href={ref.url} target="_blank" rel="noopener" class="press-ref-link" data-i18n="press.view">View</a>
              </div>
            ))}
          </div>
        ))
    }

  </div>
</div>

<style>
  .press-section { background: var(--white); color: var(--black); }
  .press-section .section-eyebrow { color: #888; }
  .press-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .press-bio {
    font-size: 1.05rem; line-height: 1.85;
    color: #444;
  }
  .press-bio strong { color: var(--black); }
  .press-bio em { color: #555; }
  .press-assets { display: flex; flex-direction: column; gap: 2px; }
  .press-asset {
    padding: 20px 24px;
    border-top: 1px solid rgba(0,0,0,0.08);
    display: flex; justify-content: space-between; align-items: center;
    transition: background 0.2s;
  }
  .press-asset:last-child { border-bottom: 1px solid rgba(0,0,0,0.08); }
  .press-asset:hover { background: rgba(0,0,0,0.04); }
  .press-asset-name { font-size: 0.85rem; font-weight: 600; color: var(--black); }
  .press-asset-meta { font-size: 0.7rem; color: #888; margin-top: 3px; }
  .press-download {
    font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: #888; text-decoration: none;
    border-bottom: 1px solid #bbb;
    padding-bottom: 2px; transition: color 0.2s, border-color 0.2s;
  }
  .press-download:hover { color: var(--black); border-color: var(--black); }
  /* Press references */
  .press-refs-title {
    font-size: 0.62rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: #888; margin: 60px 0 16px;
  }
  .press-refs-group { margin-bottom: 36px; }
  .press-refs-group-name {
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: #aaa; margin-bottom: 4px; padding-bottom: 8px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .press-ref {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 11px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    gap: 16px;
  }
  .press-ref:last-child { border-bottom: none; }
  .press-ref-left { flex: 1; min-width: 0; }
  .press-ref-title {
    font-size: 0.82rem; color: var(--black); line-height: 1.4;
  }
  .press-ref-source {
    font-size: 0.68rem; color: #888; margin-top: 2px;
  }
  .press-ref-link {
    font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: #999; text-decoration: none; white-space: nowrap;
    border-bottom: 1px solid #ccc; padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s; flex-shrink: 0;
  }
  .press-ref-link:hover { color: var(--black); border-color: var(--black); }

  @media (max-width: 768px) {
    .press-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
