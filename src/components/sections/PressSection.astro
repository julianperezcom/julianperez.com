      { title: 'RA Ibiza Weekly: Julian Perez, The Zoo Project', source: 'Resident Advisor', url: 'https://ra.co/news/26382' },
      { title: 'Guti Starts People Like Us in Ibiza', source: 'Resident Advisor', url: 'https://ra.co/news/29911' },
