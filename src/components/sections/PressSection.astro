    ],
  },
  {
    name: 'Festival & Event Coverage',
    refs: [
      { title: 'Moscow\'s Outline Festival Announces 2016 Lineup', source: 'Resident Advisor', url: 'https://ra.co/news/35024' },
      { title: 'Sunwaves Unleash Final Monster Line-Up For Their Summer Session', source: 'Trommel Music', url: 'https://trommelmusic.com/news/sunwaves-unleash-final-monster-line-up-for-their-summer-session/' },
