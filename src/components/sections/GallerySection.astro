  function buildGallery(container, files, subfolder) {
    const base = GALLERY_BASE + subfolder + '/';
    container.innerHTML = files.map(f =>
      `<div class="gallery-item"><img src="${base}${encodeURIComponent(f)}" loading="lazy" alt=""><div class="gallery-overlay"></div></div>`
    ).join('');
  }

  function shuffle(arr) {
    const a = [...arr]
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]]
    }
    return a
  }

  buildGallery(document.getElementById('gallery-flyers'), shuffle(FLYERS), 'flyers');
  buildGallery(document.getElementById('gallery-dmt'), shuffle(DMT), 'doingmything');

  function switchGallery(tab, btn) {
    document.querySelectorAll('#gallery .music-tabs .tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('gallery-flyers').style.display = tab === 'flyers' ? '' : 'none';
    document.getElementById('gallery-dmt').style.display = tab === 'dmt' ? '' : 'none';
  }
  (window as any).switchGallery = switchGallery
</script>
