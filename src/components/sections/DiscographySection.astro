---
import { getReleases } from '../../lib/sanity'

let releases: any[] = []
try {
  releases = await getReleases()
} catch (e) {
  releases = []
}

const originals    = releases.filter((r: any) => ['EP', 'Single', 'LP'].includes(r.releaseType))
const remixes      = releases.filter((r: any) => r.releaseType === 'Remix')
const appearances  = releases.filter((r: any) => r.releaseType === 'Appearance')
---

<div class="discog-section" id="discography">
  <div class="section-wrap">
    <div class="section-eyebrow" data-i18n="discog.eyebrow">Discography</div>
    <div class="section-title">Releases</div>
    <p class="section-sub"><span data-i18n="discog.sub">Full catalog synced with</span> <a href="https://www.discogs.com/artist/54394-Julian-Perez" target="_blank" style="color:#666;text-decoration:none;border-bottom:1px solid #bbb;">Discogs</a>.</p>

    <div class="music-tabs">
      <button class="tab-btn active" onclick="switchDiscog('originals', this)" data-i18n="discog.tab.originals">Originals</button>
      <button class="tab-btn" onclick="switchDiscog('remixes', this)" data-i18n="discog.tab.remixes">Remixes</button>
      <button class="tab-btn" onclick="switchDiscog('appearances', this)" data-i18n="discog.tab.appearances">Appearances</button>
    </div>

    <!-- ORIGINALS — list rows -->
    <div id="discog-originals" class="discog-list">
      {originals.length === 0 ? (
        <div style="padding:60px 0;text-align:center;color:#999;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;" data-i18n="discog.coming_soon">
          Coming soon
        </div>
      ) : (
        originals.map((r: any) => (
          <div class="discog-list-row">
            <div class="discog-list-year">{r.year}</div>
            <div class="discog-list-title">{r.title}</div>
            <div class="discog-list-label">{r.label}</div>
            <div class="discog-list-format">{r.releaseType}</div>
            <div class="discog-list-links">
              {r.discogsUrl && (
                <a href={r.discogsUrl} target="_blank" rel="noopener noreferrer" class="discog-ext-link">Discogs ↗</a>
              )}
            </div>
          </div>
        ))
      )}
    </div>

    <!-- REMIXES — list rows -->
    <div id="discog-remixes" class="discog-list" style="display:none;">
      {remixes.length === 0 ? (
        <div style="padding:60px 0;text-align:center;color:#999;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;" data-i18n="discog.coming_soon">
          Coming soon
        </div>
      ) : (
        remixes.map((r: any) => (
          <div class="discog-list-row">
            <div class="discog-list-year">{r.year}</div>
            <div class="discog-list-title">{r.title}</div>
            <div class="discog-list-label">{r.label}</div>
            <div class="discog-list-format">{r.releaseType}</div>
            <div class="discog-list-links">
              {r.discogsUrl && (
                <a href={r.discogsUrl} target="_blank" rel="noopener noreferrer" class="discog-ext-link">Discogs ↗</a>
              )}
            </div>
          </div>
        ))
      )}
    </div>

    <!-- APPEARANCES — list rows -->
    <div id="discog-appearances" class="discog-list" style="display:none;">
      {appearances.length === 0 ? (
        <div style="padding:60px 0;text-align:center;color:#999;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;" data-i18n="discog.coming_soon">
          Coming soon
        </div>
      ) : (
        appearances.map((r: any) => (
          <div class="discog-list-row">
            <div class="discog-list-year">{r.year}</div>
            <div class="discog-list-title">{r.title}</div>
            <div class="discog-list-label">{r.label}</div>
            <div class="discog-list-format">{r.releaseType}</div>
            <div class="discog-list-links">
              {r.discogsUrl && (
                <a href={r.discogsUrl} target="_blank" rel="noopener noreferrer" class="discog-ext-link">Discogs ↗</a>
              )}
            </div>
          </div>
        ))
      )}
    </div>

  </div>
</div>

<script>
  function switchDiscog(tab: string, btn: HTMLElement) {
    document.querySelectorAll('#discography .tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    (document.getElementById('discog-originals') as HTMLElement).style.display   = tab === 'originals'   ? 'flex'  : 'none';
    (document.getElementById('discog-remixes') as HTMLElement).style.display     = tab === 'remixes'     ? 'flex'  : 'none';
    (document.getElementById('discog-appearances') as HTMLElement).style.display = tab === 'appearances' ? 'flex'  : 'none';
  }

  // Expose globally so inline onclick handlers work
  (window as any).switchDiscog = switchDiscog;
</script>
