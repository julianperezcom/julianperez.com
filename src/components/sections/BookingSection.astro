---
const bookingKey   = import.meta.env.PUBLIC_WEB3FORMS_BOOKING_KEY  ?? ''
const contactKey   = import.meta.env.PUBLIC_WEB3FORMS_CONTACT_KEY  ?? ''
const hcaptchaKey  = import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY      ?? '10000000-ffff-ffff-ffff-000000000001'
---

<!-- hCaptcha SDK — explicit render so hidden-tab widget loads correctly -->
<script is:inline src="https://js.hcaptcha.com/1/api.js?render=explicit&onload=_hcLoad" async defer></script>

<!-- BOOKING -->
<div class="booking-section" id="booking">
  <div class="section-wrap">

    <!-- Tabs -->
    <div class="booking-tabs">
      <button class="booking-tab active" data-tab="booking-request" data-i18n="booking.tab.booking">Booking Request</button>
      <button class="booking-tab" data-tab="general-contact" data-i18n="booking.tab.contact">General Contact</button>
    </div>

    <!-- BOOKING REQUEST -->
    <div id="booking-request" class="booking-panel">
      <div class="booking-grid">
        <div class="booking-info">
          <div class="section-eyebrow" data-i18n="booking.eyebrow">Contact</div>
          <h2>Booking<br>Request</h2>
          <p data-i18n="booking.request.desc">Fill in the form with the event details and we'll get back to you within 48h.</p>
        </div>

        <form class="contact-form" id="form-booking">
          <!-- Web3Forms config -->
          <input type="hidden" name="access_key" value={bookingKey}>
          <input type="hidden" name="subject" value="New Booking Request – julianperez.com">
          <input type="hidden" name="from_name" value="julianperez.com">
          <input type="hidden" name="botcheck" value="">

          <div class="form-section-title" data-i18n="form.promoter">Promoter</div>
          <div class="form-row">
            <input type="text" name="first_name" placeholder="First Name" data-i18n-ph="form.first_name">
            <input type="text" name="last_name" placeholder="Last Name" data-i18n-ph="form.last_name">
          </div>
          <input type="email" name="email" placeholder="E-Mail" required data-i18n-ph="form.email">
          <input type="text" name="company" placeholder="Company Name" data-i18n-ph="form.company">
          <input type="text" name="address" placeholder="Full Address" data-i18n-ph="form.address">

          <div class="form-section-title" data-i18n="form.event">Event</div>
          <div class="form-row">
            <input type="text" name="event_name" placeholder="Event Name" data-i18n-ph="form.event_name">
            <input type="text" name="event_date" placeholder="Event Date (dd/mm/yyyy)" data-i18n-ph="form.event_date">
          </div>
          <input type="text" name="past_events" placeholder="Past Events / Artists" data-i18n-ph="form.past_events">
          <input type="text" name="lineup" placeholder="Line-up" data-i18n-ph="form.lineup">
          <div class="form-row">
            <input type="text" name="set_time" placeholder="Set Time" data-i18n-ph="form.set_time">
            <input type="text" name="offer" placeholder="Offer" data-i18n-ph="form.offer">
          </div>
          <input type="url" name="event_link" placeholder="Link (event page, FB event…)" data-i18n-ph="form.event_link">

          <div class="form-section-title" data-i18n="form.venue">Venue</div>
          <div class="form-row">
            <input type="text" name="venue_name" placeholder="Venue's Name" data-i18n-ph="form.venue_name">
            <input type="text" name="venue_capacity" placeholder="Venue's Capacity" data-i18n-ph="form.venue_capacity">
          </div>
          <div class="form-row">
            <input type="text" name="city" placeholder="City" data-i18n-ph="form.city">
            <input type="text" name="country" placeholder="Country" data-i18n-ph="form.country">
          </div>
          <input type="text" name="venue_address" placeholder="Address" data-i18n-ph="form.venue_address">
          <div class="form-row">
            <input type="url" name="venue_website" placeholder="Website" data-i18n-ph="form.website">
            <input type="text" name="airports" placeholder="Nearest Airports" data-i18n-ph="form.airports">
          </div>

          <div class="form-section-title" data-i18n="form.additional">Additional Info</div>
          <textarea name="comments" placeholder="Comments" data-i18n-ph="form.comments"></textarea>

          <!-- hCaptcha -->
          <div class="h-captcha" data-sitekey={hcaptchaKey} id="hcap-booking" style="margin:20px 0 8px;"></div>

          <div class="form-check">
            <input type="checkbox" required>
            <span><span data-i18n="booking.privacy">I have read and accept the</span> <a href="/privacy" data-i18n="booking.privacy.link">Privacy and Cookie Policy</a></span>
          </div>
          <button type="submit" id="btn-booking" data-i18n="booking.send_booking">Send Booking Request</button>
        </form>
      </div>
    </div>

    <!-- GENERAL CONTACT -->
    <div id="general-contact" class="booking-panel" style="display:none;">
      <div class="booking-grid">
        <div class="booking-info">
          <div class="section-eyebrow" data-i18n="booking.eyebrow">Contact</div>
          <h2 data-i18n-html="booking.contact.h2">General<br>Contact</h2>
          <p data-i18n="booking.contact.desc">This form is not directly managed by Julian. For press, media and general matters, fill in the form and someone from the team will get back to you shortly.</p>
        </div>

        <form class="contact-form" id="form-contact">
          <!-- Web3Forms config -->
          <input type="hidden" name="access_key" value={contactKey}>
          <input type="hidden" name="subject" value="New Contact Message – julianperez.com">
          <input type="hidden" name="from_name" value="julianperez.com">
          <input type="hidden" name="botcheck" value="">

          <div class="form-row">
            <input type="text" name="first_name" placeholder="First Name" data-i18n-ph="form.first_name">
            <input type="text" name="last_name" placeholder="Last Name" data-i18n-ph="form.last_name">
          </div>
          <input type="email" name="email" placeholder="E-Mail" required data-i18n-ph="form.email">
          <input type="text" name="subject_line" placeholder="Subject" data-i18n-ph="form.subject">
          <textarea name="message" placeholder="Message" style="height:140px;" data-i18n-ph="form.message"></textarea>

          <!-- hCaptcha -->
          <div class="h-captcha" data-sitekey={hcaptchaKey} id="hcap-contact" style="margin:20px 0 8px;"></div>

          <div class="form-check">
            <input type="checkbox" required>
            <span><span data-i18n="booking.privacy">I have read and accept the</span> <a href="/privacy" data-i18n="booking.privacy.link">Privacy and Cookie Policy</a></span>
          </div>
          <button type="submit" id="btn-contact" data-i18n="booking.send_message">Send Message</button>
        </form>
      </div>
    </div>

  </div>
</div>

<style>
  .booking-section { background: #DEDED9; }
  .booking-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--light);
    margin-bottom: 64px;
  }
  .booking-tab {
    padding: 16px 32px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    font-family: inherit;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    color: var(--gray);
    margin-bottom: -1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .booking-tab.active { color: var(--black); border-bottom-color: var(--black); }
  .booking-tab:hover { color: var(--black); }
  .booking-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 80px;
    align-items: start;
  }
  .booking-info h2 {
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  .booking-info p {
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 36px;
  }
  .form-section-title {
    font-size: 0.6rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin: 36px 0 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--light);
  }
  .form-section-title:first-child { margin-top: 0; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0 28px; }
  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 12px 0;
    border: 0;
    border-bottom: 1px solid #d8d8d8;
    outline: none;
    font-family: inherit;
    font-size: 0.88rem;
    margin-bottom: 20px;
    background: transparent;
    color: var(--black);
    transition: border-color 0.2s;
  }
  .contact-form input:focus,
  .contact-form textarea:focus { border-bottom-color: var(--black); }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: #555; }
  .contact-form textarea { height: 90px; resize: none; }
  .form-check {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin: 24px 0 36px;
    font-size: 0.8rem;
    color: var(--gray);
    line-height: 1.5;
  }
  .form-check input[type="checkbox"] {
    width: auto;
    margin: 2px 0 0;
    flex-shrink: 0;
    border: 1.5px solid #ccc;
    border-bottom: 1.5px solid #ccc;
    padding: 0;
    accent-color: var(--black);
  }
  .form-check a { color: var(--black); font-weight: 600; }
  .contact-form button[type="submit"] {
    padding: 16px 48px;
    background: var(--black);
    color: var(--white);
    border: none;
    font-family: inherit;
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .contact-form button[type="submit"]:hover:not(:disabled) { opacity: 0.7; }
  .contact-form button[type="submit"]:disabled { opacity: 0.4; cursor: default; }

  .form-success {
    padding: 48px 0;
    font-size: 0.9rem;
    color: var(--black);
    letter-spacing: 0.05em;
    line-height: 1.7;
  }
  .form-success strong { display: block; font-size: 1.1rem; margin-bottom: 8px; letter-spacing: -0.01em; }
  .form-error {
    color: #c00;
    font-size: 0.78rem;
    margin-top: 12px;
    letter-spacing: 0.03em;
  }

  @media (max-width: 768px) {
    .booking-grid { grid-template-columns: 1fr; gap: 40px; }
    .booking-info h2 { font-size: 1.8rem; }
    .booking-tab { padding: 14px 16px; font-size: 0.65rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  // ── Tab switching ────────────────────────────────────────────
  document.querySelectorAll('.booking-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const panel = (btn as HTMLElement).dataset.tab!
      document.querySelectorAll('.booking-panel').forEach(p => ((p as HTMLElement).style.display = 'none'))
      document.querySelectorAll('.booking-tab').forEach(b => b.classList.remove('active'))
      const el = document.getElementById(panel)
      if (el) el.style.display = 'block'
      btn.classList.add('active')
    })
  })

  // ── hCaptcha explicit render (handles hidden-at-load widgets) ─
  ;(window as any)._hcLoad = function () {
    const hc = (window as any).hcaptcha
    if (!hc) return
    document.querySelectorAll('.h-captcha').forEach((el: Element) => {
      if (!el.hasAttribute('data-hcaptcha-widget-id')) {
        hc.render(el as HTMLElement)
      }
    })
  }

  // ── Form submission ──────────────────────────────────────────
  async function submitForm(formId: string, btnId: string) {
    const form = document.getElementById(formId) as HTMLFormElement | null
    if (!form) return

    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      const btn = document.getElementById(btnId) as HTMLButtonElement
      const originalText = btn.textContent!
      btn.disabled = true
      btn.textContent = 'Sending…'

      // Remove previous error
      form.querySelectorAll('.form-error').forEach(el => el.remove())

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        })
        const data = await res.json()

        if (data.success) {
          // Replace form with confirmation
          const grid = form.closest('.booking-grid')
          if (grid) {
            const info = grid.querySelector('.booking-info')
            form.innerHTML = ''
            form.insertAdjacentHTML('beforeend', `
              <div class="form-success">
                <strong>${(window as any).__t__?.['booking.success'] || '✓ Sent successfully'}</strong>
                ${(window as any).__t__?.['booking.success.sub'] || "We'll get back to you shortly."}
              </div>
            `)
          }
        } else {
          throw new Error(data.message ?? 'Unknown error')
        }
      } catch (err: any) {
        btn.disabled = false
        btn.textContent = originalText
        const msg = document.createElement('p')
        msg.className = 'form-error'
        msg.textContent = (window as any).__t__?.['booking.error'] || 'Error sending the form. Please try again.'
        form.appendChild(msg)
      }
    })
  }

  submitForm('form-booking', 'btn-booking')
  submitForm('form-contact', 'btn-contact')
</script>
