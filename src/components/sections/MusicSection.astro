---
import { getSets, getTracks } from '../../lib/sanity'

let sets: any[] = []
let tracks: any[] = []

try {
  [sets, tracks] = await Promise.all([getSets(), getTracks()])
} catch (e) {
  sets = []
  tracks = []
}

function getYouTubeId(url: string): string | null {
  if (!url) return null
  const m = url.match(/[?&]v=([^&]+)/) ?? url.match(/youtu\.be\/([^?]+)/)
  return m ? m[1] : null
}

const scSets = sets.filter((s: any) => s.soundcloudUrl)
---

<div id="music">
  <div class="section-wrap">
    <div class="section-eyebrow">Music</div>
    <div class="section-title">Sets &amp; Tracks</div>
    <p class="section-sub">Mixes, directo y producciones originales.</p>

    <div class="music-tabs">
      <button class="tab-btn active" onclick="switchMusic('sets',this)">DJ Sets &amp; Podcasts</button>
      <button class="tab-btn" onclick="switchMusic('live',this)">Live Videos</button>
      <button class="tab-btn" onclick="switchMusic('tracks',this)">Tracks</button>
    </div>

    <!-- ── DJ SETS & PODCASTS ── -->
    <div id="tab-sets">

      <!-- YouTube playlist embed -->
      <div class="playlist-embed-wrap">
        <div class="playlist-label">
          <span style="color:#FF0000;">●</span> YouTube · DJ Sets &amp; Podcasts
          <a href="https://www.youtube.com/playlist?list=PLLRxDKy3npviQXeQI5fRtp0FGNKJIfYNN"
             target="_blank" rel="noopener noreferrer" class="playlist-ext">Ver playlist ↗</a>
        </div>
        <div class="yt-playlist-player">
          <iframe
            src="https://www.youtube.com/embed/videoseries?list=PLLRxDKy3npviQXeQI5fRtp0FGNKJIfYNN"
            title="Julian Perez DJ Sets & Podcasts"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <!-- SoundCloud individual sets -->
      {scSets.length > 0 && (
        <div class="playlist-label" style="margin-top:48px;">
          <span style="color:#FF5500;">●</span> SoundCloud · Sets &amp; Podcasts
          <a href="https://soundcloud.com/julianperez/sets/sets-podcasts"
             target="_blank" rel="noopener noreferrer" class="playlist-ext">Ver playlist ↗</a>
        </div>
      )}
      {scSets.map((set: any) => (
        <div class="embed-entry">
          <div class="embed-meta">
            <span class="embed-meta-title">{set.title}</span>
            {set.venue && <span class="embed-meta-venue">{set.venue}</span>}
            {set.duration && <span class="embed-meta-duration">{set.duration}</span>}
          </div>
          <div
            class="embed-player sc-player"
            data-src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(set.soundcloudUrl)}&color=%23ff5500&auto_play=true&hide_related=true&show_comments=false&show_user=true&show_reposts=false&visual=false`}
          >
            <div class="embed-play-btn sc">
              <span class="embed-play-icon">▶</span>
              <span>Escuchar en SoundCloud</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- ── LIVE VIDEOS ── -->
    <div id="tab-live" style="display:none;">
      <div class="playlist-embed-wrap">
        <div class="playlist-label">
          <span style="color:#FF0000;">●</span> YouTube · Live Videos
          <a href="https://www.youtube.com/playlist?list=PLLRxDKy3npvgR9aNV0vZJSYdLlA8nqzlV"
             target="_blank" rel="noopener noreferrer" class="playlist-ext">Ver playlist ↗</a>
        </div>
        <div class="yt-playlist-player">
          <iframe
            src="https://www.youtube.com/embed/videoseries?list=PLLRxDKy3npvgR9aNV0vZJSYdLlA8nqzlV"
            title="Julian Perez Live Videos"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>

    <!-- ── TRACKS ── -->
    <div id="tab-tracks" style="display:none;">
      <div class="playlist-label" style="margin-bottom:28px;">
        <span style="color:#FF0000;">●</span> YouTube · Releases
        <a href="https://www.youtube.com/@julianperezcom/releases"
           target="_blank" rel="noopener noreferrer" class="playlist-ext">Ver canal ↗</a>
      </div>
      {tracks.length === 0 ? (
        <div style="padding:60px 0;text-align:center;color:#999;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;">
          Próximamente
        </div>
      ) : (
        <div class="tracks-grid">
          {tracks.map((track: any) => {
            const vid = getYouTubeId(track.youtubeUrl)
            return (
              <div class="track-card">
                <div
                  class="embed-player yt-player"
                  data-src={vid ? `https://www.youtube.com/embed/${vid}?autoplay=1` : ''}
                  style={vid ? `background-image:url(https://img.youtube.com/vi/${vid}/hqdefault.jpg)` : 'background:#111'}
                >
                  <div class="embed-play-btn yt">
                    <span class="yt-icon">▶</span>
                  </div>
                </div>
                <div class="track-title">{track.title}</div>
              </div>
            )
          })}
        </div>
      )}
    </div>

  </div>
</div>

<style>
  .playlist-label {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .playlist-ext {
    color: #aaa;
    text-decoration: none;
    margin-left: auto;
    font-size: 0.65rem;
  }
  .playlist-ext:hover { color: var(--black); }

  .playlist-embed-wrap { margin-bottom: 16px; }

  /* 16:9 responsive YouTube playlist player */
  .yt-playlist-player {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #111;
  }
  .yt-playlist-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* SoundCloud individual sets */
  .embed-entry { margin-bottom: 28px; }
  .embed-meta {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .embed-meta-title { font-weight: 700; font-size: 0.88rem; }
  .embed-meta-venue { font-size: 0.75rem; color: #888; }
  .embed-meta-duration { font-size: 0.72rem; color: #aaa; margin-left: auto; }

  .embed-player {
    width: 100%;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  .sc-player {
    height: 166px;
    background: #f2f2f2;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sc-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .yt-player {
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .yt-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .embed-play-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: 2px;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    pointer-events: none;
  }
  .embed-play-btn.sc { background: #FF5500; color: #fff; }
  .embed-play-btn.yt { background: rgba(0,0,0,0.65); color: #fff; }
  .embed-play-icon { font-size: 0.9rem; }
  .yt-icon { font-size: 1.6rem; color: #FF0000; }
  .embed-player:hover .embed-play-btn { opacity: 0.85; }

  /* Tracks grid */
  .tracks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
  }
  .track-card { display: flex; flex-direction: column; gap: 10px; }
  .track-title { font-size: 0.8rem; font-weight: 600; line-height: 1.35; }
</style>

<script>
  function switchMusic(tab: string, btn: HTMLElement) {
    document.querySelectorAll('#music .tab-btn').forEach(b => b.classList.remove('active'))
    btn.classList.add('active');
    (document.getElementById('tab-sets') as HTMLElement).style.display   = tab === 'sets'   ? 'block' : 'none';
    (document.getElementById('tab-live') as HTMLElement).style.display   = tab === 'live'   ? 'block' : 'none';
    (document.getElementById('tab-tracks') as HTMLElement).style.display = tab === 'tracks' ? 'block' : 'none'
  }
  (window as any).switchMusic = switchMusic

  // Click-to-embed for SoundCloud sets and individual YT track cards
  document.querySelectorAll<HTMLElement>('.embed-player').forEach(player => {
    player.addEventListener('click', () => {
      const src = player.dataset.src
      if (!src || player.querySelector('iframe')) return
      const iframe = document.createElement('iframe')
      iframe.src = src
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture'
      iframe.allowFullscreen = true
      player.innerHTML = ''
      player.style.backgroundImage = 'none'
      player.appendChild(iframe)
      player.style.cursor = 'default'
    })
  })
</script>
