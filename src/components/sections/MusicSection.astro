---
import { getSets, getTracks } from '../../lib/sanity'

let sets: any[] = []
let tracks: any[] = []

try {
  [sets, tracks] = await Promise.all([getSets(), getTracks()])
} catch (e) {
  sets = []
  tracks = []
}

function getYouTubeId(url: string): string | null {
  if (!url) return null
  const m = url.match(/[?&]v=([^&]+)/) ?? url.match(/youtu\.be\/([^?]+)/)
  return m ? m[1] : null
}

const scSets = sets.filter((s: any) => s.soundcloudUrl)
const ytSets = sets.filter((s: any) => s.youtubeUrl && !s.soundcloudUrl)
---

<!-- MUSIC: SETS & TRACKS -->
<div id="music">
  <div class="section-wrap">
    <div class="section-eyebrow">Music</div>
    <div class="section-title">Sets &amp; Tracks</div>
    <p class="section-sub">Mixes de DJ en directo y producciones originales.</p>

    <div class="music-tabs">
      <button class="tab-btn active" onclick="switchMusic('sets',this)">DJ Sets</button>
      <button class="tab-btn" onclick="switchMusic('tracks',this)">Tracks</button>
    </div>

    <!-- SETS -->
    <div id="tab-sets">

      <!-- SoundCloud sets -->
      {scSets.length > 0 && (
        <div class="sets-source-label">
          <span style="color:#FF5500;">●</span> SoundCloud
        </div>
      )}
      {scSets.map((set: any) => (
        <div class="embed-entry">
          <div class="embed-meta">
            <span class="embed-meta-title">{set.title}</span>
            {set.venue && <span class="embed-meta-venue">{set.venue}</span>}
            {set.duration && <span class="embed-meta-duration">{set.duration}</span>}
          </div>
          <div
            class="embed-player sc-player"
            data-src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(set.soundcloudUrl)}&color=%23ff5500&auto_play=true&hide_related=true&show_comments=false&show_user=true&show_reposts=false&visual=false`}
          >
            <div class="embed-play-btn sc">
              <span class="embed-play-icon">▶</span>
              <span>Escuchar en SoundCloud</span>
            </div>
          </div>
        </div>
      ))}

      <!-- YouTube sets -->
      {ytSets.length > 0 && (
        <div class="sets-source-label" style="margin-top:40px;">
          <span style="color:#FF0000;">●</span> YouTube
        </div>
      )}
      {ytSets.map((set: any) => {
        const vid = getYouTubeId(set.youtubeUrl)
        return vid && (
          <div class="embed-entry">
            <div class="embed-meta">
              <span class="embed-meta-title">{set.title}</span>
              {set.venue && <span class="embed-meta-venue">{set.venue}</span>}
            </div>
            <div
              class="embed-player yt-player"
              data-src={`https://www.youtube.com/embed/${vid}?autoplay=1`}
              style={`background-image:url(https://img.youtube.com/vi/${vid}/hqdefault.jpg)`}
            >
              <div class="embed-play-btn yt">
                <span class="embed-play-icon yt-icon">▶</span>
              </div>
            </div>
          </div>
        )
      })}

      {sets.length === 0 && (
        <div style="padding:60px 0;text-align:center;color:#999;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;">
          Próximamente
        </div>
      )}
    </div>

    <!-- TRACKS (YouTube Releases) -->
    <div id="tab-tracks" style="display:none;">
      {tracks.length === 0 ? (
        <div style="padding:60px 0;text-align:center;color:#999;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;">
          Próximamente
        </div>
      ) : (
        <div class="tracks-grid">
          {tracks.map((track: any) => {
            const vid = getYouTubeId(track.youtubeUrl)
            return (
              <div class="track-card">
                <div
                  class="embed-player yt-player"
                  data-src={vid ? `https://www.youtube.com/embed/${vid}?autoplay=1` : ''}
                  style={vid ? `background-image:url(https://img.youtube.com/vi/${vid}/hqdefault.jpg)` : 'background:#111'}
                >
                  <div class="embed-play-btn yt">
                    <span class="embed-play-icon yt-icon">▶</span>
                  </div>
                </div>
                <div class="track-title">{track.title}</div>
              </div>
            )
          })}
        </div>
      )}
    </div>

  </div>
</div>

<style>
  .sets-source-label {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .embed-entry {
    margin-bottom: 32px;
  }

  .embed-meta {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .embed-meta-title {
    font-weight: 700;
    font-size: 0.88rem;
  }
  .embed-meta-venue {
    font-size: 0.75rem;
    color: #888;
  }
  .embed-meta-duration {
    font-size: 0.72rem;
    color: #aaa;
    margin-left: auto;
  }

  /* Generic player container */
  .embed-player {
    width: 100%;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  /* SoundCloud: fixed height, grey bg */
  .sc-player {
    height: 166px;
    background: #f2f2f2;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sc-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* YouTube: 16:9 ratio, thumbnail bg */
  .yt-player {
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .yt-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Play buttons */
  .embed-play-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: 2px;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    transition: opacity 0.15s;
    pointer-events: none;
  }
  .embed-play-btn.sc {
    background: #FF5500;
    color: #fff;
  }
  .embed-play-btn.yt {
    background: rgba(0,0,0,0.7);
    color: #fff;
  }
  .embed-play-icon {
    font-size: 0.9rem;
  }
  .yt-icon {
    font-size: 1.4rem;
    color: #FF0000;
  }
  .embed-player:hover .embed-play-btn {
    opacity: 0.85;
  }

  /* Tracks grid */
  .tracks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
  }
  .track-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .track-title {
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--black);
  }
</style>

<script>
  function switchMusic(tab: string, btn: HTMLElement) {
    document.querySelectorAll('#music .tab-btn').forEach(b => b.classList.remove('active'))
    btn.classList.add('active');
    (document.getElementById('tab-sets') as HTMLElement).style.display   = tab === 'sets'   ? 'block' : 'none';
    (document.getElementById('tab-tracks') as HTMLElement).style.display = tab === 'tracks' ? 'block' : 'none'
  }
  (window as any).switchMusic = switchMusic

  // Click-to-embed: replace play button with iframe on click
  document.querySelectorAll<HTMLElement>('.embed-player').forEach(player => {
    player.addEventListener('click', () => {
      const src = player.dataset.src
      if (!src || player.querySelector('iframe')) return
      const iframe = document.createElement('iframe')
      iframe.src = src
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture'
      iframe.allowFullscreen = true
      // Clear thumbnail/button, insert iframe
      player.innerHTML = ''
      player.style.backgroundImage = 'none'
      player.appendChild(iframe)
      player.style.cursor = 'default'
    })
  })
</script>
