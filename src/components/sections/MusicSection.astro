---
import { getSets, getLiveVideos, getTracks } from '../../lib/sanity'

let sets: any[] = []
let liveVideos: any[] = []
let tracks: any[] = []

try {
  [sets, liveVideos, tracks] = await Promise.all([getSets(), getLiveVideos(), getTracks()])
} catch (e) {
  sets = []; liveVideos = []; tracks = []
}

function getYouTubeId(url: string): string | null {
  if (!url) return null
  const m = url.match(/[?&]v=([^&]+)/) ?? url.match(/youtu\.be\/([^?]+)/)
  return m ? m[1] : null
}

const scSets = sets.filter((s: any) => s.soundcloudUrl)

// Fetch SC thumbnails via oEmbed at build time
async function getScThumbnail(url: string): Promise<string | null> {
  try {
    const res = await fetch(`https://soundcloud.com/oembed?url=${encodeURIComponent(url)}&format=json`)
    if (!res.ok) return null
    const data: any = await res.json()
    return data.thumbnail_url ?? null
  } catch { return null }
}

const scThumbnails: Record<string, string | null> = {}
await Promise.all(
  scSets.map(async (s: any) => {
    scThumbnails[s.soundcloudUrl] = await getScThumbnail(s.soundcloudUrl)
  })
)
const ytSets = sets.filter((s: any) => s.youtubeUrl)
---

<div id="music">
  <div class="section-wrap">
    <div class="section-eyebrow" data-i18n="music.eyebrow">Music</div>
    <div class="section-title" style="color:#C8C7C3;">Sets &amp; Tracks</div>
    <p class="section-sub" data-i18n="music.sub">Mixes, live sets and original productions.</p>

    <div class="music-tabs">
      <button class="tab-btn active" onclick="switchMusic('sets',this)" data-i18n="music.tab.sets">DJ Sets &amp; Podcasts</button>
      <button class="tab-btn" onclick="switchMusic('live',this)" data-i18n="music.tab.live">Live Videos</button>
      <button class="tab-btn" onclick="switchMusic('tracks',this)" data-i18n="music.tab.tracks">Tracks</button>
    </div>

    <!-- ── DJ SETS & PODCASTS ── -->
    <div id="tab-sets">

      {ytSets.length > 0 && (
        <p class="tab-source-label">
          <span class="dot yt">●</span> YouTube
          <a href="https://www.youtube.com/playlist?list=PLLRxDKy3npviQXeQI5fRtp0FGNKJIfYNN"
             target="_blank" rel="noopener noreferrer" class="source-link">Ver playlist ↗</a>
        </p>
      )}
      <div class="video-grid">
        {ytSets.map((set: any) => {
          const vid = getYouTubeId(set.youtubeUrl)
          return vid && (
            <div class="video-card">
              <div class="video-thumb yt-thumb"
                data-src={`https://www.youtube.com/embed/${vid}?autoplay=1`}
                style={`background-image:url(https://img.youtube.com/vi/${vid}/hqdefault.jpg)`}>
                <div class="play-btn"><span class="yt-play">▶</span></div>
              </div>
              <div class="video-title">{set.title}</div>
              {set.duration && <div class="video-meta">{set.duration}</div>}
            </div>
          )
        })}
      </div>

      {scSets.length > 0 && (
        <p class="tab-source-label" style="margin-top:48px;">
          <span class="dot sc">●</span> SoundCloud
          <a href="https://soundcloud.com/julianperez/sets/sets-podcasts"
             target="_blank" rel="noopener noreferrer" class="source-link">Ver playlist ↗</a>
        </p>
      )}
      <div class="video-grid">
        {scSets.map((set: any) => (
          <div class="video-card">
            <div class="video-thumb sc-thumb"
              data-src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(set.soundcloudUrl)}&color=%23ff5500&auto_play=true&hide_related=true&show_comments=false&show_user=true&visual=false`}
              style={scThumbnails[set.soundcloudUrl] ? `background-image:url(${scThumbnails[set.soundcloudUrl]})` : ''}>
              <div class="play-btn sc-play-btn">
                <span class="sc-play">▶</span>
                <span class="sc-play-label">SoundCloud</span>
              </div>
            </div>
            <div class="video-title">{set.title}</div>
            {set.duration && <div class="video-meta">{set.duration}</div>}
          </div>
        ))}
      </div>

      {sets.length === 0 && (
        <div class="empty-state" data-i18n="music.coming_soon">Coming soon</div>
      )}
    </div>

    <!-- ── LIVE VIDEOS ── -->
    <div id="tab-live" style="display:none;">
      <p class="tab-source-label">
        <span class="dot yt">●</span> YouTube
        <a href="https://www.youtube.com/playlist?list=PLLRxDKy3npvgR9aNV0vZJSYdLlA8nqzlV"
           target="_blank" rel="noopener noreferrer" class="source-link">Ver playlist ↗</a>
      </p>
      <div class="video-grid">
        {liveVideos.map((v: any) => {
          const vid = getYouTubeId(v.youtubeUrl)
          return vid && (
            <div class="video-card">
              <div class="video-thumb yt-thumb"
                data-src={`https://www.youtube.com/embed/${vid}?autoplay=1`}
                style={`background-image:url(https://img.youtube.com/vi/${vid}/hqdefault.jpg)`}>
                <div class="play-btn"><span class="yt-play">▶</span></div>
              </div>
              <div class="video-title">{v.title}</div>
            </div>
          )
        })}
      </div>
      {liveVideos.length === 0 && <div class="empty-state" data-i18n="music.coming_soon">Coming soon</div>}
    </div>

    <!-- ── TRACKS ── -->
    <div id="tab-tracks" style="display:none;">
      <p class="tab-source-label">
        <span class="dot yt">●</span> YouTube · Releases
        <a href="https://www.youtube.com/@julianperezcom/releases"
           target="_blank" rel="noopener noreferrer" class="source-link">Ver canal ↗</a>
      </p>
      <div class="video-grid">
        {tracks.map((track: any) => (
          <div class="video-card">
            <div class="video-thumb yt-thumb"
              data-src={track.youtubePlaylistId
                ? `https://www.youtube.com/embed/videoseries?list=${track.youtubePlaylistId}&autoplay=1`
                : ''}
              style={track.thumbnail ? `background-image:url(${track.thumbnail})` : 'background:#111'}>
              <div class="play-btn"><span class="yt-play">▶</span></div>
              {track.videoCount > 1 && (
                <div class="track-count">{track.videoCount} tracks</div>
              )}
            </div>
            <div class="video-title">{track.title}</div>
          </div>
        ))}
      </div>
      {tracks.length === 0 && <div class="empty-state" data-i18n="music.coming_soon">Coming soon</div>}
    </div>

  </div>
</div>

<style>
  .tab-source-label {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .dot { font-size: 0.5rem; }
  .dot.yt { color: #FF0000; }
  .dot.sc { color: #FF5500; }
  .source-link { color: #aaa; text-decoration: none; margin-left: auto; font-size: 0.65rem; }
  .source-link:hover { color: var(--black); }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 8px;
  }

  .video-card { display: flex; flex-direction: column; gap: 8px; }

  /* Thumbnail */
  .video-thumb {
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .yt-thumb { background-color: #111; }
  .sc-thumb { background-color: #f2f2f2; aspect-ratio: 1 / 1; background-size: cover; background-position: center; }

  .video-thumb iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Play buttons */
  .play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .yt-play {
    font-size: 1.6rem;
    color: #FF0000;
    background: rgba(0,0,0,0.6);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 4px;
    transition: transform 0.15s;
  }
  .video-thumb:hover .yt-play { transform: scale(1.1); }

  .sc-play-btn {
    flex-direction: column;
    gap: 4px;
    background: #FF5500;
    padding: 8px 16px;
    border-radius: 2px;
  }
  .sc-play { color: #fff; font-size: 1rem; }
  .sc-play-label { color: #fff; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; }

  /* Text */
  .track-count {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0,0,0,0.75);
    color: #fff;
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    text-transform: uppercase;
  }
  .video-title { font-size: 0.75rem; font-weight: 600; line-height: 1.35; color: var(--black); }
  .video-meta { font-size: 0.68rem; color: #999; }

  .empty-state {
    padding: 60px 0;
    text-align: center;
    color: #999;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Mobile: 2 columns → 1 column */
  @media (max-width: 768px) {
    .video-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  }
  @media (max-width: 480px) {
    .video-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  function switchMusic(tab: string, btn: HTMLElement) {
    document.querySelectorAll('#music .tab-btn').forEach(b => b.classList.remove('active'))
    btn.classList.add('active');
    (document.getElementById('tab-sets') as HTMLElement).style.display   = tab === 'sets'   ? 'block' : 'none';
    (document.getElementById('tab-live') as HTMLElement).style.display   = tab === 'live'   ? 'block' : 'none';
    (document.getElementById('tab-tracks') as HTMLElement).style.display = tab === 'tracks' ? 'block' : 'none'
  }
  (window as any).switchMusic = switchMusic

  document.querySelectorAll<HTMLElement>('.video-thumb').forEach(thumb => {
    thumb.addEventListener('click', () => {
      const src = thumb.dataset.src
      if (!src || thumb.querySelector('iframe')) return
      const iframe = document.createElement('iframe')
      iframe.src = src
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture'
      iframe.allowFullscreen = true
      thumb.innerHTML = ''
      thumb.style.backgroundImage = 'none'
      thumb.appendChild(iframe)
      thumb.style.cursor = 'default'
    })
  })
</script>
