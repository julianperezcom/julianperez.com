<!-- HERO VIDEO -->
<div class="hero" id="hero">
  <video id="heroVideo" autoplay muted playsinline
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;"></video>
  <div class="video-overlay"></div>
  <div class="video-caption" id="videoCaption"></div>
  <div class="hero-dots" id="heroDots"></div>
  <button class="hero-unmute" id="heroUnmute">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" id="speakerIcon"/>
      <line x1="23" y1="9" x2="17" y2="15" id="muteX1" style="display:none"/>
      <line x1="17" y1="9" x2="23" y2="15" id="muteX2" style="display:none"/>
      <path d="M15.54 8.46a5 5 0 0 1 0 7.07" id="wave1"/>
      <path d="M19.07 4.93a10 10 0 0 1 0 14.14" id="wave2"/>
    </svg>
    <span id="unmuteLabel" data-i18n="hero.unmute">Unmute</span>
  </button>
</div>
