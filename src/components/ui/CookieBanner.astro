---
---
<div id="cookie-banner" style="display:none;">
  <p id="cookie-text">
    This website uses cookies to ensure you get the best experience.
    <a href="/privacy" id="cookie-link">Privacy Policy</a>
  </p>
  <div class="cookie-actions">
    <button id="cookie-accept">Accept</button>
    <button id="cookie-reject">Reject</button>
  </div>
</div>

<style>
  #cookie-banner {
    position: fixed;
    bottom: 24px;
    left: 24px;
    right: 24px;
    max-width: 560px;
    background: #1a1a1a;
    color: #ccc;
    padding: 20px 24px;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    box-shadow: 0 4px 32px rgba(0,0,0,0.5);
  }
  #cookie-banner p {
    font-size: 0.78rem;
    line-height: 1.6;
    margin: 0;
  }
  #cookie-banner a {
    color: #fff;
    font-weight: 600;
  }
  .cookie-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  .cookie-actions button {
    padding: 10px 20px;
    font-family: inherit;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: opacity 0.2s;
  }
  #cookie-accept { background: #fff; color: #0E0E0E; }
  #cookie-reject { background: transparent; color: #666; border: 1px solid #333 !important; }
  .cookie-actions button:hover { opacity: 0.75; }
  @media (max-width: 600px) {
    #cookie-banner { flex-direction: column; align-items: flex-start; bottom: 0; left: 0; right: 0; max-width: 100%; }
  }
</style>

<script>
  (function () {
    const COOKIE_KEY = 'cookie_consent'
    const banner = document.getElementById('cookie-banner')!
    const acceptBtn = document.getElementById('cookie-accept')!
    const rejectBtn = document.getElementById('cookie-reject')!
    const text = document.getElementById('cookie-text')!
    const link = document.getElementById('cookie-link')!

    // i18n
    function updateText() {
      const lang = (window as any).__lang__ || 'en'
      if (lang === 'es') {
        text.innerHTML = 'Este sitio utiliza cookies para ofrecerte la mejor experiencia. <a href="/privacy" id="cookie-link" style="color:#fff;font-weight:600;">Política de privacidad</a>'
        acceptBtn.textContent = 'Aceptar'
        rejectBtn.textContent = 'Rechazar'
      } else {
        text.innerHTML = 'This website uses cookies to ensure you get the best experience. <a href="/privacy" style="color:#fff;font-weight:600;">Privacy Policy</a>'
        acceptBtn.textContent = 'Accept'
        rejectBtn.textContent = 'Reject'
      }
    }

    if (!localStorage.getItem(COOKIE_KEY)) {
      banner!.style.display = 'flex'
      updateText()
      document.addEventListener('langchange', updateText)
    }

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem(COOKIE_KEY, 'accepted')
      banner!.style.display = 'none'
    })
    rejectBtn.addEventListener('click', () => {
      localStorage.setItem(COOKIE_KEY, 'rejected')
      banner!.style.display = 'none'
    })
  })()
</script>
